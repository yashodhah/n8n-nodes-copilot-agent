{
  "name": "n8n-nodes-copilot-agent",
  "version": "0.1.0",
  "description": "n8n community node for GitHub Copilot via the @github/copilot-sdk",
  "license": "MIT",
  "homepage": "https://github.com/yashodhah/copilot-agent#readme",
  "keywords": [
    "n8n-community-node-package",
    "github",
    "copilot",
    "ai",
    "llm",
    "automation",
    "workflow"
  ],
  "author": { "name": "yashodhah", "email": "dev.h.yashodha@gmail.com" },
  "repository": {
    "type": "git",
    "url": "https://github.com/yashodhah/copilot-agent.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "dev:external": "n8n-node dev --external-n8n",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "predev": "node scripts/postinstall.js",
    "predev:external": "node scripts/postinstall.js",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "main": "dist/index.js",
  "files": ["dist", "scripts/postinstall.js"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": ["dist/credentials/CopilotAgentApi.credentials.js"],
    "nodes": ["dist/nodes/CopilotAgent/CopilotAgent.node.js"]
  },
  "dependencies": { "@github/copilot-sdk": "0.2.2" },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "release-it": "19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": { "n8n-workflow": "2.16.0" }
}
