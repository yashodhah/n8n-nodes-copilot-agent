FROM node:22-bookworm-slim

RUN apt-get update \
	&& apt-get install -y --no-install-recommends bash curl ca-certificates \
	&& rm -rf /var/lib/apt/lists/*

# Install Copilot CLI from npm
# Override version at build time if needed: --build-arg COPILOT_CLI_VERSION=0.0.369
ARG COPILOT_CLI_VERSION=latest
RUN npm_config_ignore_scripts=false npm install -g @github/copilot@${COPILOT_CLI_VERSION} \
	&& command -v copilot >/dev/null

RUN groupadd --system copilot \
	&& useradd --system --gid copilot --create-home --shell /usr/sbin/nologin copilot
USER copilot

EXPOSE 8080

CMD ["copilot", "--server", "--host", "0.0.0.0", "--port", "8080"]
